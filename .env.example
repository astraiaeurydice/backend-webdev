# Copy to .env.local and fill in values. On Railway, set these in the dashboard (not in git).

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me
JWT_SECRET=change_me
# Vercel URL — Google OAuth redirect + email verification land here
FRONTEND_URL=http://localhost:3000
# Public Railway/backend URL — used for email links & OAuth callback (no trailing slash)
DEFAULT_URI=http://127.0.0.1:8000
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://user:password@127.0.0.1:3306/dbname?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> Google OAuth (KnpU) ###
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match Google Console → Authorized redirect URIs exactly
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/connect/google/check
###< Google OAuth ###

###> symfony/mailer (Brevo SMTP) ###
# Brevo: smtp://USER@smtp-brevo.com:KEY@smtp-relay.brevo.com:587 (URL-encode special chars)
MAILER_DSN=null://null
MAILER_FROM_ADDRESS=
MAILER_FROM_NAME=K-Dream Merchandise
CONTACT_NOTIFY_EMAIL=
###< symfony/mailer ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me
###< lexik/jwt-authentication-bundle ###

###> workerman / onesignal ###
WORKERMAN_INTERNAL_URL=http://localhost:8091
# Shared secret for internal pushes (API -> WebSocket service). Leave empty in local dev if you want.
WORKERMAN_INTERNAL_TOKEN=
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_API_KEY=your-onesignal-rest-api-key
###< workerman / onesignal ###
