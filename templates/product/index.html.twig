{% extends 'base.html.twig' %}

{% block title %}Product index{% endblock %}

{% block body %}
    <h1 class="text-3xl font-bold mb-6">Product index</h1>

    <table class="min-w-full border border-gray-200 rounded-lg shadow-sm mb-6">
        <thead class="bg-gray-100 text-gray-700">
            <tr>
                <th class="px-4 py-2 text-left">Id</th>
                <th class="px-4 py-2 text-left">Name</th>
                <th class="px-4 py-2 text-left">Price</th>
                <th class="px-4 py-2 text-left">Description</th>
                <th class="px-4 py-2 text-left">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
        {% for product in products %}
            <tr class="hover:bg-gray-50">
                <td class="px-4 py-2">{{ product.id }}</td>
                <td class="px-4 py-2">{{ product.name }}</td>
                <td class="px-4 py-2">{{ product.price }}</td>
                <td class="px-4 py-2">{{ product.description }}</td>
                <td class="px-4 py-2 space-x-2">
                    <a href="{{ path('app_product_show', {'id': product.id}) }}"
                       class="text-blue-600 hover:underline">show</a>
                    <a href="{{ path('app_product_edit', {'id': product.id}) }}"
                       class="text-green-600 hover:underline">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" class="px-4 py-3 text-center text-gray-500">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_product_new') }}"
       class="inline-block px-4 py-2 rounded bg-blue-600 text-white hover:bg-blue-700 transition">
        Create new
    </a>
{% endblock %}
